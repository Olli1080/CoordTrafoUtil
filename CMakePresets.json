{
    "version": 2,
  
    "configurePresets": [
      {
        "name": "default",
        "generator": "Visual Studio 18 2026",
        "binaryDir": "${sourceDir}/build/default",
        "cacheVariables": {
          "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/${presetName}",
          "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/externals/vcpkg/scripts/buildsystems/vcpkg.cmake"
        }
      },
      {
        "name": "tests",
        "inherits": "default",
        "binaryDir": "${sourceDir}/build/tests",
        "cacheVariables": {
          "BUILD_TESTS": "ON"
        }
      }
    ]
  }