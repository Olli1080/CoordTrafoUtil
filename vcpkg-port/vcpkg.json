{
  "name": "base-transformation",
  "version": "0.1.0",
  "description": "A C++20 coordinate transformation utility library.",
  "homepage": "https://github.com/Olli1080/CoordTrafoUtil",
  "license": "MIT",
  "supports": "cxx20",
  "dependencies": [
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "default-features": [
    "eigen",
    "pcl"
  ],
  "features": {
    "eigen": {
      "description": "Build with eigen plugin",
      "dependencies": [
        "eigen3"
      ]
    },
    "pcl": {
      "description": "Build with pcl plugin",
      "dependencies": [
        "pcl"
      ]
    },
    "tests": {
      "description": "Build tests",
      "dependencies": [
        "gtest"
      ]
    }
  }
}